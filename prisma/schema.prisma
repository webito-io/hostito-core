// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String?
  firstName String?
  lastName  String?
  phone     String?  @unique
  role      Role    @relation(fields: [roleId], references: [id])
  roleId    Int
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId Int
  auditLogs AuditLog[]
  status    Status   @default(ACTIVE)
  emailVerified       Boolean   @default(false)
  verificationToken   String?
  resetPasswordToken  String?
  resetPasswordExpiry DateTime?
  googleId           String?   @unique
  githubId           String?   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Role {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  permissions Permission[]
  users       User[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Permission {
  id       Int    @id @default(autoincrement())
  resource String
  action   String
  scope    String
  roles    Role[]

  @@unique([resource, action, scope])
}

enum Status {
  ACTIVE
  SUSPENDED
  BLOCKED
  CANCELLED
}

model Organization {
  id        Int       @id @default(autoincrement())
  name      String
  phone     String?
  address   String?
  city      String?
  state     String?
  zip       String?
  country   String?   // ISO 3166-1 alpha-2 (US, DE, IR, ...)
  users     User[]
  invoices  Invoice[]
  orders    Order[]
  transactions Transaction[]
  domains  Domain[]
  services Service[]
  carts Cart[]
  auditLogs AuditLog[]
  currency   Currency @relation(fields: [currencyId], references: [id])
  currencyId Int
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Currency {
  id        Int      @id @default(autoincrement())
  code      String   @unique // USD, EUR, IRR
  name      String           // US Dollar
  symbol    String           // $
  rate      Float            // base currency rate
  organizations Organization[]
  orders        Order[]
  coupons       Coupon[]
  invoices      Invoice[]
  products Product[]
  transactions Transaction[]
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id        Int       @id @default(autoincrement())
  total     Float
  tax     Float
  subtotal     Float
  discount     Float
  shipping     Float
  status OrderStatus @default(PENDING)
  currency   Currency @relation(fields: [currencyId], references: [id])
  currencyId Int
  invoices Invoice[]
  items OrderItem[]
  coupon   Coupon? @relation(fields: [couponId], references: [id])
  couponId Int?
  service   Service?
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId Int
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model OrderItem {
  id          Int      @id @default(autoincrement())
  description String
  quantity    Int      @default(1)
  unitPrice   Float
  total       Float
  order       Order    @relation(fields: [orderId], references: [id])
  orderId     Int
  product     Product  @relation(fields: [productId], references: [id])
  productId   Int
  variant     ProductVariant @relation(fields: [variantId], references: [id])
  variantId   Int
  createdAt   DateTime @default(now())
}


model Cart {
  id             Int        @id @default(autoincrement())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId Int        @unique
  status         CartStatus @default(ACTIVE)
  couponCode     String?
  items          CartItem[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

enum CartStatus {
  ACTIVE
  PROCESSING
}

model CartItem {
  id        Int      @id @default(autoincrement())
  cart      Cart     @relation(fields: [cartId], references: [id])
  cartId    Int
  product   Product  @relation(fields: [productId], references: [id])
  productId Int
  variant   ProductVariant @relation(fields: [variantId], references: [id])
  variantId Int
  config    Json?    // { domain: 'example.com', os: 'ubuntu' }
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Invoice {
  id        Int       @id @default(autoincrement())
  total     Float
  tax     Float
  subtotal     Float
  discount     Float
  shipping     Float
  status InvoiceStatus @default(PENDING)
  currency   Currency @relation(fields: [currencyId], references: [id])
  currencyId Int
  transactions Transaction[]
  items InvoiceItem[]
  order   Order? @relation(fields: [orderId], references: [id])
  orderId Int?
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId Int
  dueDate DateTime?
  paidAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model InvoiceItem {
  id          Int      @id @default(autoincrement())
  description String
  quantity    Int      @default(1)
  unitPrice   Float
  total       Float
  invoice     Invoice  @relation(fields: [invoiceId], references: [id])
  invoiceId   Int
  service     Service? @relation(fields: [serviceId], references: [id])
  serviceId   Int?
  domain      Domain?  @relation(fields: [domainId], references: [id])
  domainId    Int?
  createdAt   DateTime @default(now())
}

enum OrderStatus {
  PENDING
  ACTIVE
  CANCELLED
  FRAUD
}

enum InvoiceStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
  OVERDUE
}


model Transaction {
  id             Int               @id @default(autoincrement())
  amount         Float
  type           TransactionType   // CREDIT, DEBIT
  status         TransactionStatus @default(PENDING)
  gateway   PaymentGateway? @relation(fields: [gatewayId], references: [id])
  gatewayId Int?
  gatewayRef     String?           // transaction id from gateway
  invoice        Invoice?          @relation(fields: [invoiceId], references: [id])
  invoiceId      Int?
  organization   Organization      @relation(fields: [organizationId], references: [id])
  organizationId Int
  currency       Currency          @relation(fields: [currencyId], references: [id])
  currencyId     Int
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

enum TransactionType {
  CREDIT
  DEBIT
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model PaymentGateway {
  id           Int      @id @default(autoincrement())
  name         String   @unique // stripe, paypal, crypto
  isActive     Boolean  @default(false)
  config       Json?    // api keys
  transactions Transaction[]
  updatedAt    DateTime @updatedAt
}

model Category {
  id          Int        @id @default(autoincrement())
  name        String
  slug        String     @unique
  description String?
  order       Int        @default(0)
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  parentId    Int?
  children    Category[] @relation("CategoryHierarchy")
  products    Product[]
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Product {
  id          Int              @id @default(autoincrement())
  name        String
  description String?
  type        ProductType
  currency    Currency         @relation(fields: [currencyId], references: [id])
  currencyId  Int
  category    Category?        @relation(fields: [categoryId], references: [id])
  categoryId  Int?
  server      Server?          @relation(fields: [serverId], references: [id])
  serverId    Int?
  tld         String?          @unique // .com, .net, .ir — only for DOMAIN products
  isActive    Boolean          @default(true)
  config      Json?
  variants    ProductVariant[]
  services    Service[]
  cartItems   CartItem[]
  orderItems  OrderItem[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

enum ProductType {
  SERVICE
  DOMAIN
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  SEMIANNUAL
  ANNUAL
  BIENNIAL
  TRIENNIAL
  ONETIME
}

enum VariantAction {
  RECURRING
  REGISTER
  RENEW
  TRANSFER
  SETUP
}

model ProductVariant {
  id         Int           @id @default(autoincrement())
  product    Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId  Int
  action     VariantAction
  cycle      BillingCycle
  price      Float
  cartItems  CartItem[]
  orderItems OrderItem[]
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@unique([productId, action, cycle])
}

model Domain {
  id             Int          @id @default(autoincrement())
  name           String       @unique
  status         DomainStatus @default(PENDING)
  registrar      Registrar?   @relation(fields: [registrarId], references: [id])
  registrarId    Int?
  expiresAt      DateTime?
  autoRenew      Boolean      @default(true)
  nameservers    String[]     @default([])
  isLocked       Boolean      @default(true)
  privacy        Boolean      @default(false)
  authCode       String?
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId Int
  service        Service?
  invoiceItems   InvoiceItem[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Registrar {
  id        Int      @id @default(autoincrement())
  name      String   @unique // spaceship, dynadot
  isActive  Boolean  @default(false)
  config    Json?    // api keys, secrets
  domains   Domain[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum DomainStatus {
  PENDING
  ACTIVE
  EXPIRED
  CANCELLED
  TRANSFERRED
}

model Service {
  id             Int           @id @default(autoincrement())
  status         ServiceStatus @default(PENDING)
  username       String?
  password       String?       // encrypted
  domain         Domain?       @relation(fields: [domainId], references: [id])
  domainId       Int?          @unique
  product        Product       @relation(fields: [productId], references: [id])
  productId      Int
  order          Order         @relation(fields: [orderId], references: [id])
  orderId        Int @unique
  organization   Organization  @relation(fields: [organizationId], references: [id])
  organizationId Int
  server   Server? @relation(fields: [serverId], references: [id])
  serverId Int?
  nextDueDate    DateTime?
  invoiceItems   InvoiceItem[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

enum ServiceStatus {
  PENDING
  ACTIVE
  SUSPENDED
  CANCELLED
}


model Provisioner {
  id       Int      @id @default(autoincrement())
  name     String   @unique // cpanel, proxmox, v2ray, license
  isActive Boolean  @default(false)
  servers  Server[]
  config   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Server {
  id            Int      @id @default(autoincrement())
  name          String
  hostname      String
  ip            String
  port          Int      @default(2087)
  credentials   Json?
  isActive      Boolean  @default(true)
  maxAccounts   Int?
  provisioner   Provisioner @relation(fields: [provisionerId], references: [id])
  provisionerId Int
  products      Product[]
  services      Service[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Tax {
  id        Int      @id @default(autoincrement())
  name      String   // VAT, GST
  rate      Float    // 20.00 = 20%
  country   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Coupon {
  id          Int          @id @default(autoincrement())
  code        String       @unique
  type        CouponType
  value       Float
  currency    Currency?    @relation(fields: [currencyId], references: [id])
  currencyId  Int?        
  maxUses     Int?
  usedCount   Int          @default(0)
  expiresAt   DateTime?
  isActive    Boolean      @default(true)
  orders      Order[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

enum CouponType {
  PERCENTAGE
  FIXED
}


model Announcement {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NotificationProvider {
  id        Int      @id @default(autoincrement())
  name      String   @unique // smtp, sms, push
  isActive  Boolean  @default(false)
  config    Json?
  logs      NotificationLog[]
  updatedAt DateTime @updatedAt
}

model NotificationLog {
  id         Int      @id @default(autoincrement())
  type       String   // email, sms, push
  to         String
  subject    String?
  status     String   // sent, failed
  error      String?
  provider   NotificationProvider @relation(fields: [providerId], references: [id])
  providerId Int
  createdAt  DateTime @default(now())
}

model NotificationTemplate {
  id        Int      @id @default(autoincrement())
  name      String   @unique // invoice.paid, service.created
  subject   String?
  body      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model AuditLog {
  id             Int      @id @default(autoincrement())
  action         String   // user.login, invoice.paid, service.suspended
  entity         String   // User, Invoice, Service
  entityId       Int?
  oldValue       Json?  
  newValue       Json?    
  ip             String?
  userAgent      String?
  user           User?    @relation(fields: [userId], references: [id])
  userId         Int?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  organizationId Int?
  createdAt      DateTime @default(now())
}

model Setting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     Json     @default("\"\"")
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OutboxEvent {
  id          Int              @id @default(autoincrement())
  type        String           // provisioner, domain, notification, event
  queue       String           // BullMQ queue name
  jobName     String           // BullMQ job name
  payload     Json             // serialized job data
  status      OutboxEventStatus @default(PENDING)
  retries     Int              @default(0)
  lastError   String?
  processedAt DateTime?
  createdAt   DateTime         @default(now())
}

enum OutboxEventStatus {
  PENDING
  PROCESSED
  FAILED
}